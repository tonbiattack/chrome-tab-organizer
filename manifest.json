{
  "manifest_version": 3,
  "name": "Tab Organizer",
  "version": "1.0.0",
  "description": "重複タブを削除し、ドメインごとにタブを整理するChrome拡張",
  "permissions": [
    "tabs",
    "tabGroups"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "dedup-tabs": {
      "suggested_key": { "default": "Alt+Shift+D" },
      "description": "重複タブを削除"
    },
    "sort-tabs": {
      "suggested_key": { "default": "Alt+Shift+G" },
      "description": "ドメインごとに整理"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
